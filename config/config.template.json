{
  "paths": {
    "baseDir": "/path/to/your/base/directory",
    "repoPath": "/path/to/your/mobile-app-repo",
    "screenshotsDir": "/path/to/figma-screenshots",
    "docsPath": "/path/to/checkout-docs"
  },
  "confluence": {
    "url": "https://your-domain.atlassian.net",
    "email": "your.email@company.com",
    "token": "YOUR_CONFLUENCE_API_TOKEN_HERE"
  },
  "pages": {
    "mobileApp": {
      "id": "YOUR_MOBILE_APP_PAGE_ID",
      "name": "Mobile App Documentation"
    },
    "checkout": {
      "id": "YOUR_CHECKOUT_PAGE_ID",
      "name": "Checkout Documentation"
    },
    "paecs": {
      "id": "YOUR_PAECS_PAGE_ID",
      "name": "PAECS Handbook"
    }
  },
  "figma": {
    "token": "YOUR_FIGMA_TOKEN_HERE",
    "fileKeys": [
      "YOUR_FIGMA_FILE_KEY_1",
      "YOUR_FIGMA_FILE_KEY_2"
    ]
  },
  "sentry": {
    "org": "your-org",
    "project": "your-project",
    "token": "YOUR_SENTRY_AUTH_TOKEN_HERE"
  },
  "jira": {
    "baseUrl": "https://your-domain.atlassian.net",
    "email": "your.email@company.com",
    "token": "YOUR_JIRA_API_TOKEN_HERE",
    "project": "YOUR_PROJECT_KEY"
  },
  "notifications": {
    "email": "your.email@company.com",
    "slack": {
      "enabled": false,
      "webhookUrl": "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
    }
  },
  "schedule": {
    "documentation": "0 9 * * 1",
    "sentry": "0 9 * * *"
  },
  "settings": {
    "dryRun": false,
    "minChangesToUpdate": 1,
    "screensDir": "src/screens",
    "queriesDir": "apollo/queries",
    "mixpanelDir": "vendor/Mixpanel"
  }
}
